# Fill these with values from Firebase console
# Go to: https://console.firebase.google.com/
# Project Settings → Your Apps → Web

# Get from Firebase config
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE

# Format: your-project.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=YOUR_AUTH_DOMAIN_HERE

# Your project ID (without .firebaseapp.com)
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Format: your-project.appspot.com
VITE_FIREBASE_STORAGE_BUCKET=YOUR_STORAGE_BUCKET_HERE

# Numeric ID
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE

# Long ID format: 1:number:web:string
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE

